    { "data": { "id": "bromite", "label": "Bromite", "wiki": "", "url": "https://www.bromite.org", "logo": "https://www.bromite.org/static/bromite_icon_128.png", "noWiki": true, "wikiNote": "Bromite is an open-source web browser for Android based on Chromium. It is designed to provide a clutter-free browsing experience with a focus on privacy and security. The project implements a built-in ad-blocking engine and numerous patches to prevent browser fingerprinting and remove Google-specific telemetry. While historically significant as a leading privacy fork of Chromium, its development cycle became irregular in later years.", "wikiUrl": "https://www.bromite.org", "author": "Romeo Masci" } },
    { "data": { "id": "cromite", "label": "Cromite", "wiki": "", "url": "https://github.com/uazo/cromite", "logo": "https://raw.githubusercontent.com/uazo/cromite/master/build/android/chrome/res/drawable-hdpi/app_icon.png", "noWiki": true, "wikiNote": "Cromite is an open-source Chromium fork for Android, developed as a direct successor to the Bromite project. It continues the mission of providing a privacy-hardened browsing experience by integrating Bromite's original security patches while ensuring more frequent updates synchronized with the upstream Chromium releases. It is currently recognized as the primary maintained alternative for users seeking the features of the original Bromite on modern systems.", "wikiUrl": "https://github.com/uazo/cromite", "author": "uazo" } },
